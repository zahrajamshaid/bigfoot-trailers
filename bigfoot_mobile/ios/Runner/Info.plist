<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>es</string>
	</array>
	<key>CFBundleDisplayName</key>
	<string>Bigfoot Trailers</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>bigfoot_mobile</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- User-facing permission prompts (required by image_picker, geolocator, etc.) -->
	<key>NSCameraUsageDescription</key>
	<string>Bigfoot Trailers uses the camera to capture QC inspection photos and proof-of-delivery shots.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Bigfoot Trailers needs access to your photo library to attach inspection and delivery photos.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Bigfoot Trailers saves captured photos to your library.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Bigfoot Trailers records the delivery location when a driver marks a delivery complete.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Bigfoot Trailers records the delivery location when a driver marks a delivery complete.</string>

	<!-- External URL schemes opened by url_launcher (tel:, sms:, mailto:, Google Maps) -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>tel</string>
		<string>sms</string>
		<string>mailto</string>
		<string>https</string>
		<string>http</string>
		<string>comgooglemaps</string>
		<string>googlechromes</string>
	</array>

	<!-- Background modes — needed by Firebase Cloud Messaging -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>

	<!--
	  App Transport Security. Production uses a valid HTTPS origin, so no
	  global arbitrary-loads exception is required. NSAllowsLocalNetworking
	  permits HTTP traffic to LAN IPs (e.g. 192.168.x.x) for local dev
	  without opening up the rest of the internet to cleartext.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<!--
	  Encryption export-compliance declaration. The app uses only standard
	  HTTPS / TLS, which is exempt from US export rules — declaring this
	  here skips the "Does your app use encryption?" question on every
	  TestFlight / App Store upload.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
