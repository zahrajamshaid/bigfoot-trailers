#include "Generated.xcconfig"

// Manual signing for CI release builds (TestFlight / App Store).
// Overrides the project-level "iPhone Developer" default so xcodebuild
// archive uses the Apple Distribution cert installed on the runner.
CODE_SIGN_STYLE = Manual
DEVELOPMENT_TEAM = QNC26CJD2B
CODE_SIGN_IDENTITY = Apple Distribution
PROVISIONING_PROFILE_SPECIFIER = Bigfoot Trailers App Store
