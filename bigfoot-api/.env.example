# =============================================================================
# BIGFOOT TRAILERS API — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ---- Application ----
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# ---- Database (PostgreSQL 15+) ----
DATABASE_URL=postgresql://bigfoot:bigfoot_secret@localhost:5432/bigfoot_db?schema=public

# ---- Redis (sessions + BullMQ job queue) ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- JWT Authentication ----
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d
# Grace window for benign refresh-token races (app suspended mid-rotation,
# proactive + reactive refresh firing together, network drop + retry).
# Past this window the offending token is rejected with 401 but OTHER
# sessions are left alone — we no longer mass-revoke.
JWT_REFRESH_REUSE_GRACE=5m

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ---- DigitalOcean Spaces (S3-compatible) ----
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=bigfoot-files
DO_SPACES_ACCESS_KEY=your_spaces_access_key
DO_SPACES_SECRET_KEY=your_spaces_secret_key
DO_SPACES_CDN_URL=https://bigfoot-files.nyc3.cdn.digitaloceanspaces.com

# ---- Firebase Cloud Messaging (FCM) ----
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ---- Twilio SMS ----
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ---- Rate Limiting ----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
