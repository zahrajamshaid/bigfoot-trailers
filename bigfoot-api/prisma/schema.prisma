// =============================================================================
// BIGFOOT TRAILERS — Prisma Schema v2
// Converted from bigfoot_schema_final.sql (27 tables, 16 enums, 3 views)
// PostgreSQL 15+ | Aligned to bigfoot_complete_workflows_v3.pdf
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS (16 total — exact match to PostgreSQL CREATE TYPE statements)
// =============================================================================

enum TrailerSeries {
  xp
  yeti
  deck_over
  gooseneck_dump
  // Inventory-only models (Triple Crown, Enclosed, Misc). Trailers in this
  // series skip workflow_template lookup and are created straight in
  // ready_for_delivery — they're tracked for stock but not built on a line.
  inventory
  // Gooseneck Yeti — mirrors the gooseneck_dump workflow except step 3
  // (finish weld) runs through YETI_FIN instead of GN_FIN. Paint defaults
  // to PAINT_B like other goosenecks; hydraulics + the rest of the line
  // stay identical to gooseneck_dump.
  gooseneck_yeti
  // CXP — small pull-behind that shares the gooseneck production line
  // 1-for-1: same 12 workflow steps including the GN_FIN + QC_2 bypass
  // and always PAINT_B. Kept as its own series so it doesn't skew
  // gooseneck reporting and so a customer looking at their trailer
  // sees "CXP" rather than "Gooseneck". Two models today: 10 CXP and
  // 14K CXP.
  cxp

  @@map("trailer_series_enum")
}

enum TrailerStatus {
  pending_production
  in_production
  ready_for_delivery
  in_transit
  delivered
  on_hold

  @@map("trailer_status_enum")
}

enum TrailerSaleStatus {
  available
  sale_pending
  sold

  @@map("trailer_sale_status_enum")
}

enum DeliveryType {
  factory_pickup
  stack_to_dealer
  stack_to_location
  single_pull

  @@map("delivery_type_enum")
}

enum DeliveryStatus {
  scheduled
  in_transit
  delivered
  failed

  @@map("delivery_status_enum")
}

enum DeliveryBatchStatus {
  building
  scheduled
  in_transit
  complete

  @@map("delivery_batch_status_enum")
}

enum ProductionStepStatus {
  waiting
  active
  complete
  rework

  @@map("production_step_status_enum")
}

enum DeptCompletionType {
  one_tap
  qc_checklist

  @@map("dept_completion_type_enum")
}

enum QcResult {
  pass
  fail

  @@map("qc_result_enum")
}

enum UserRole {
  owner
  production_manager
  transport_manager
  qc_inspector
  worker
  sales
  driver
  office
  purchasing
  // Parts staff — read-only access to pending work orders + every jig
  // department queue so they can stage parts ahead of the welders.
  parts

  @@map("user_role_enum")
}

enum CustomerType {
  end_user
  dealer
  stock_location

  @@map("customer_type_enum")
}

enum SmsType {
  trailer_complete
  driver_en_route
  delivery_complete

  @@map("sms_type_enum")
}

enum SmsStatus {
  queued
  sent
  delivered
  failed

  @@map("sms_status_enum")
}

enum NotificationType {
  qc_fail
  qc_ready
  trailer_stalled
  worker_message
  payment_not_collected
  delivery_complete
  // Fires when a jig department's queue (active + waiting steps) drops
  // below 3. Notifies production managers so they enter more SOs before
  // the line starves. Self-applies via ALTER TYPE in the notification
  // path so prod can pick it up without a separate db push.
  jig_queue_low
  // A customer accepted their estimate in QuickBooks (e.g. via the email
  // link). The nightly reconciliation detects it, auto-converts the SO into
  // a production trailer, and notifies the office with this type.
  estimate_accepted

  @@map("notification_type_enum")
}

enum BatchType {
  dealer
  bf_location

  @@map("batch_type_enum")
}

enum PhotoType {
  proof_of_delivery
  damage

  @@map("photo_type_enum")
}

enum PaymentMethod {
  cashiers_check
  debit
  cash

  @@map("payment_method_enum")
}

enum QcSeriesScope {
  xp
  yeti
  deck_over
  gooseneck_dump
  all

  @@map("qc_series_scope_enum")
}

// =============================================================================
// SECTION 1: CORE — LOCATIONS, TRAILER MODELS, CUSTOMERS, TRAILERS
// =============================================================================

model Location {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(20)
  name       String   @db.VarChar(100)
  city       String   @db.VarChar(100)
  state      String   @db.Char(2)
  address    String?
  shortLabel String?  @map("short_label") @db.VarChar(8)
  isFactory  Boolean  @default(false) @map("is_factory")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  trailers                Trailer[]         @relation("TrailerCurrentLocation")
  intendedStockTrailers   Trailer[]         @relation("TrailerIntendedStockLocation")
  users                   User[]
  deliveryBatches         DeliveryBatch[]
  deliveries              Delivery[]
  locationReceipts        LocationReceipt[]
  stockCustomers          Customer[]        @relation("CustomerStockLocation")

  @@map("locations")
}

model TrailerModel {
  id           Int           @id @default(autoincrement())
  code         String        @unique @db.VarChar(30)
  displayName  String        @map("display_name") @db.VarChar(100)
  series       TrailerSeries
  weightRating String?       @map("weight_rating") @db.VarChar(20)
  isActive     Boolean       @default(true) @map("is_active")
  // Phase 2 — QuickBooks + configurator. qboItemId links this model to its
  // QBO Product/Service; basePrice mirrors the QBO price; spec holds the
  // structured SpecAttributes the configurator renders into the line-1
  // description; baseBomId points at the model's base BOM.
  qboItemId    String?       @map("qbo_item_id") @db.VarChar(50)
  basePrice    Decimal?      @map("base_price") @db.Decimal(12, 2)
  spec         Json?
  baseBomId    BigInt?       @map("base_bom_id")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  trailers    Trailer[]
  pointValues PointValue[]
  stageCosts  TrailerModelStageCost[]

  @@map("trailer_models")
}

model Customer {
  id              BigInt       @id @default(autoincrement())
  name            String       @db.VarChar(200)
  company         String?      @db.VarChar(200)
  smsPhone        String?      @map("sms_phone") @db.VarChar(20)
  email           String?      @db.VarChar(200)
  billingAddress  String?      @map("billing_address")
  deliveryAddress String?      @map("delivery_address")
  customerType    CustomerType @default(end_user) @map("customer_type")
  smsOptOut       Boolean      @default(false) @map("sms_opt_out")
  qbCustomerId    String?      @map("qb_customer_id") @db.VarChar(50)
  notes           String?
  // Required when customerType = stock_location: which yard this stock
  // customer represents. Lets the trailer-create flow auto-fill the stock
  // destination when this customer is picked.
  stockLocationId Int?         @map("stock_location_id")
  // Phase 2 — QuickBooks. taxExempt/resaleCertNo drive the estimate's tax
  // handling; the qbSync* fields track the customer↔QBO sync + surface the
  // nightly reconciliation status.
  taxExempt       Boolean      @default(false) @map("tax_exempt")
  resaleCertNo    String?      @map("resale_cert_no") @db.VarChar(60)
  qbSyncState     QbSyncState  @default(pending) @map("qb_sync_state")
  qbLastSyncedAt  DateTime?    @map("qb_last_synced_at") @db.Timestamptz
  qbSyncError     String?      @map("qb_sync_error")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  trailers      Trailer[]
  stockLocation Location?    @relation("CustomerStockLocation", fields: [stockLocationId], references: [id])
  salesOrders   SalesOrder[]

  @@map("customers")
}

model Trailer {
  id                BigInt  @id @default(autoincrement())
  soNumber          String  @unique @map("so_number") @db.VarChar(30)
  vinNumber         String? @unique @map("vin_number") @db.VarChar(17)
  trailerModelId    Int     @map("trailer_model_id")
  customerId        BigInt? @map("customer_id")
  currentLocationId Int     @map("current_location_id")
  // Where a stock build is destined to ship after production. Captured at
  // creation so transport knows the target yard, but the trailer stays at
  // the factory until a stack_to_location delivery actually moves it. Null
  // for customer trailers.
  intendedStockLocationId Int? @map("intended_stock_location_id")
  createdByUserId   BigInt  @map("created_by_user_id")

  // Physical specs
  color        String? @db.VarChar(60)
  sizeFt       String? @map("size_ft") @db.VarChar(10)
  optionsNotes String? @map("options_notes")
  specialNote  String? @map("special_note") @db.VarChar(500)

  // QB integration
  qbSoPdfStorageUrl String?   @map("qb_so_pdf_storage_url")
  qbSoPdfStorageKey String?   @map("qb_so_pdf_storage_key") @db.VarChar(300)
  qbSoId            String?   @map("qb_so_id") @db.VarChar(50)
  qbInvoicedAt      DateTime? @map("qb_invoiced_at") @db.Timestamptz
  // Order date pulled from the QB packing-slip PDF (the "Date:" field).
  // Extracted on PDF upload + backfilled retroactively. Date-only — no
  // timezone since the PDF carries no time-of-day.
  qbSoDate          DateTime? @map("qb_so_date") @db.Date

  // Status & workflow control
  status         TrailerStatus     @default(pending_production)
  saleStatus     TrailerSaleStatus @default(available) @map("sale_status")
  globalPriority Int               @default(9999) @map("global_priority")
  isStockBuild   Boolean           @default(false) @map("is_stock_build")
  isHot          Boolean           @default(false) @map("is_hot")
  customerLocked Boolean           @default(false) @map("customer_locked")

  // Free-text buyer name captured when a stock / no-customer trailer is
  // marked sold. Kept as plain text on purpose — customer records will be
  // owned by the GoHighLevel integration, not this table.
  soldToName String? @map("sold_to_name") @db.VarChar(200)

  /// Timestamp of the most recent saleStatus → `sold` flip. Nullable so
  /// unsold trailers don't need a bogus value. Populated by the service
  /// wherever saleStatus flips to `sold` (and cleared when flipped away).
  /// Sales reporting (Health Check → Sales) uses this instead of
  /// createdAt / updatedAt — the former misses back-catalog sales, the
  /// latter drifts on any later edit (delivery flip, address change,
  /// etc.). Backfilled from the audit_log by seed-backfill-sold-at for
  /// historical rows.
  soldAt DateTime? @map("sold_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  trailerModel      TrailerModel       @relation(fields: [trailerModelId], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  currentLocation        Location  @relation("TrailerCurrentLocation", fields: [currentLocationId], references: [id])
  intendedStockLocation  Location? @relation("TrailerIntendedStockLocation", fields: [intendedStockLocationId], references: [id])
  createdByUser     User               @relation("TrailerCreatedBy", fields: [createdByUserId], references: [id])
  addons            TrailerAddon[]
  productionSteps   ProductionStep[]
  qcInspections     QcInspection[]
  qcPhotos          QcPhoto[]
  workerMessages    WorkerMessage[]
  deliveries        Delivery[]
  locationReceipts  LocationReceipt[]
  smsLogs           SmsLog[]
  // Phase 2 — the app-native Sales Order this trailer was converted from
  // (one SO → one trailer on estimate accept). Null for legacy/manual builds.
  salesOrder        SalesOrder?        @relation("TrailerSalesOrder")
  pushNotifications PushNotification[]
  stallAlerts       StallAlert[]

  @@index([status, globalPriority, createdAt(sort: Desc)], map: "idx_trailers_status_priority")
  @@index([saleStatus], map: "idx_trailers_sale_status")
  // Sales-count queries in Health Check filter on soldAt in a period
  // window and read isStockBuild to split customer-orders from
  // open-stock. Indexing (soldAt DESC, isStockBuild) keeps the scan
  // small on a growing table.
  @@index([soldAt(sort: Desc), isStockBuild], map: "idx_trailers_sold_at")
  @@index([customerId, status], map: "idx_trailers_customer_status")
  @@index([currentLocationId, status], map: "idx_trailers_location_status")
  @@index([isHot, status], map: "idx_trailers_hot_status")
  @@index([trailerModelId], map: "idx_trailers_model")
  @@map("trailers")
}

/// An option/add-on line item on a trailer (extra D-rings, winch plate, …).
///
/// Options are the #1 source of rebuilds: one gets added after the trailer is
/// already past weld, nobody sees it, and the trailer is finished wrong. The
/// fields below exist to close that hole:
///
///   • installDepartmentId — WHO fits it. That department must acknowledge the
///     option before it can answer its QC questions. Other departments see it
///     but can skip it (they don't fit it).
///   • addedDuringProduction — the option arrived AFTER the build started, so
///     it surfaces on the admin / production-manager dashboard until the PM
///     acknowledges it (and can roll the trailer back a stage to fit it).
model TrailerAddon {
  id        BigInt   @id @default(autoincrement())
  trailerId BigInt   @map("trailer_id")
  addonName String   @map("addon_name") @db.VarChar(150)
  notes     String?
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz

  addedByUserId       BigInt? @map("added_by_user_id")

  /// Added after the trailer entered production. Drives the dashboard alert.
  addedDuringProduction  Boolean   @default(false) @map("added_during_production")
  /// Which step the build was on when it was added — "added past WELD".
  addedAtStepOrder       Int?      @map("added_at_step_order")
  addedAtDepartmentId    Int?      @map("added_at_department_id")
  /// Cleared off the dashboard once the production manager has seen it.
  pmAcknowledgedAt       DateTime? @map("pm_acknowledged_at") @db.Timestamptz
  pmAcknowledgedByUserId BigInt?   @map("pm_acknowledged_by_user_id")

  // Relations
  trailer            Trailer     @relation(fields: [trailerId], references: [id], onDelete: Cascade)
  addedAtDepartment  Department? @relation("AddonAddedAtDept", fields: [addedAtDepartmentId], references: [id])
  addedByUser        User?       @relation("AddonAddedBy", fields: [addedByUserId], references: [id])

  /// Every department that has to fit some part of this option. An option can
  /// need more than one (D-rings might be welded at JIG and touched up at
  /// PAINT), and EACH of them has to acknowledge its own part — which is why
  /// the acknowledgement lives on the join row, not on the option.
  departments TrailerAddonDept[]

  @@index([trailerId], map: "idx_trailer_addons_trailer")
  @@index([addedDuringProduction, pmAcknowledgedAt], map: "idx_trailer_addons_pending_ack")
  @@map("trailer_addons")
}

/// One department's responsibility for one option — and its acknowledgement.
///
/// An option with no rows here is visible to everyone and blocks nobody, so a
/// missing assignment can never stall the line.
model TrailerAddonDept {
  id           BigInt @id @default(autoincrement())
  addonId      BigInt @map("addon_id")
  departmentId Int    @map("department_id")

  /// This department has fitted its part. Required before it can complete its
  /// step. Each department acknowledges independently.
  acknowledgedAt       DateTime? @map("acknowledged_at") @db.Timestamptz
  acknowledgedByUserId BigInt?   @map("acknowledged_by_user_id")

  addon              TrailerAddon @relation(fields: [addonId], references: [id], onDelete: Cascade)
  department         Department   @relation("AddonInstallDept", fields: [departmentId], references: [id])
  acknowledgedByUser User?        @relation("AddonAckBy", fields: [acknowledgedByUserId], references: [id])

  // One row per (option, department) — acknowledging twice is a no-op.
  @@unique([addonId, departmentId], map: "uq_addon_department")
  @@index([departmentId, acknowledgedAt], map: "idx_addon_dept_pending")
  @@map("trailer_addon_departments")
}

// =============================================================================
// SECTION 2: PRODUCTION WORKFLOW
// =============================================================================

model Department {
  id                  Int                @id @default(autoincrement())
  code                String             @unique @db.VarChar(30)
  displayName         String             @map("display_name") @db.VarChar(100)
  isQcStep            Boolean            @default(false) @map("is_qc_step")
  completionType      DeptCompletionType @default(one_tap) @map("completion_type")
  stallThresholdHours Int                @default(48) @map("stall_threshold_hours")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  workflowTemplates WorkflowTemplate[]
  productionSteps   ProductionStep[]
  users             User[]
  qcChecklistItems  QcChecklistItem[]
  qcReworkTargets   QcInspection[]     @relation("ReworkTargetDept")
  // Options this department is responsible for fitting (and must acknowledge).
  installedAddons   TrailerAddonDept[] @relation("AddonInstallDept")
  addonsAddedHere   TrailerAddon[]     @relation("AddonAddedAtDept")
  pointValues       PointValue[]
  deptDollarRates   DeptDollarRate[]
  payrollRecords    PayrollRecord[]
  stallAlerts       StallAlert[]
  stageCosts        TrailerModelStageCost[]

  @@map("departments")
}

model WorkflowTemplate {
  id           Int           @id @default(autoincrement())
  series       TrailerSeries
  departmentId Int           @map("department_id")
  stepOrder    Int           @map("step_order") @db.SmallInt

  // Relations
  department Department @relation(fields: [departmentId], references: [id])

  @@unique([series, stepOrder])
  @@map("workflow_templates")
}

model User {
  id                  BigInt    @id @default(autoincrement())
  email               String?   @unique @db.VarChar(200)
  fullName            String    @map("full_name") @db.VarChar(150)
  phone               String?   @db.VarChar(20)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  role                UserRole
  primaryDepartmentId Int?      @map("primary_department_id")
  /// Additional departments this user can view queues for (beyond their
  /// primaryDepartmentId). Used for "master" accounts that span multiple
  /// physical departments — e.g. a paint-master who covers PAINT_A + PAINT_B,
  /// or a wire/hydraulics master covering WIRE + HYDRAULICS. Plain Int[],
  /// not FK-enforced (paint booths aren't going to be deleted).
  extraDepartmentIds  Int[]     @default([]) @map("extra_department_ids")
  primaryLocationId   Int?      @map("primary_location_id")
  pushToken           String?   @map("push_token")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deactivatedAt       DateTime? @map("deactivated_at") @db.Timestamptz

  // Relations
  primaryDepartment Department?        @relation(fields: [primaryDepartmentId], references: [id])
  primaryLocation   Location?          @relation(fields: [primaryLocationId], references: [id])
  createdTrailers   Trailer[]          @relation("TrailerCreatedBy")
  completedSteps    ProductionStep[]   @relation("StepCompletedBy")
  // Option accountability — who added an option, and who acknowledged fitting it.
  addedAddons       TrailerAddon[]     @relation("AddonAddedBy")
  acknowledgedAddons TrailerAddonDept[] @relation("AddonAckBy")
  stepReversals     StepReversal[]
  sentMessages      WorkerMessage[]    @relation("MessageFrom")
  receivedMessages  WorkerMessage[]    @relation("MessageTo")
  qcInspections     QcInspection[]
  payrollRecords    PayrollRecord[]
  lockedPayrolls    PayrollRecord[]    @relation("PayrollLockedBy")
  driverDeliveries  Delivery[]         @relation("DeliveryDriver")
  createdDeliveries Delivery[]         @relation("DeliveryCreatedBy")
  driverBatches     DeliveryBatch[]    @relation("BatchDriver")
  createdBatches    DeliveryBatch[]    @relation("BatchCreatedBy")
  locationReceipts  LocationReceipt[]
  pushNotifications PushNotification[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  productionStepChecks ProductionStepCheck[]
  postedAnnouncements  SystemAnnouncement[]      @relation("AnnouncementPostedBy")
  announcementAcks     SystemAnnouncementAck[]

  @@index([role, isActive], map: "idx_users_role_active")
  @@map("users")
}

model ProductionStep {
  id                BigInt               @id @default(autoincrement())
  trailerId         BigInt               @map("trailer_id")
  departmentId      Int                  @map("department_id")
  stepOrder         Int                  @map("step_order") @db.SmallInt
  status            ProductionStepStatus @default(waiting)
  queuePosition     Int?                 @map("queue_position")
  completedByUserId BigInt?              @map("completed_by_user_id")

  // Rework tracking
  isRework    Boolean @default(false) @map("is_rework")
  reworkCount Int     @default(0) @map("rework_count") @db.SmallInt

  // Timestamps
  becameActiveAt DateTime? @map("became_active_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz

  // Payroll: 0 if is_rework = TRUE
  pointsAwarded Decimal @default(0) @map("points_awarded") @db.Decimal(6, 2)

  // Relations
  trailer                 Trailer        @relation(fields: [trailerId], references: [id])
  department              Department     @relation(fields: [departmentId], references: [id])
  completedByUser         User?          @relation("StepCompletedBy", fields: [completedByUserId], references: [id])
  qcInspections           QcInspection[] @relation("InspectionStep")
  reworkedFromInspections QcInspection[] @relation("ReworkSentToStep")
  stepReversals           StepReversal[]
  stallAlerts             StallAlert[]
  selfChecks              ProductionStepCheck[]

  @@unique([trailerId, departmentId, stepOrder])
  @@index([departmentId, status, queuePosition], map: "idx_production_steps_dept_status")
  @@index([trailerId, stepOrder], map: "idx_production_steps_trailer")
  @@map("production_steps")
}

model StepReversal {
  id               BigInt   @id @default(autoincrement())
  productionStepId BigInt   @map("production_step_id")
  reversedByUserId BigInt   @map("reversed_by_user_id")
  reason           String?
  reversedAt       DateTime @default(now()) @map("reversed_at") @db.Timestamptz

  // Relations
  productionStep ProductionStep @relation(fields: [productionStepId], references: [id], onDelete: Cascade)
  reversedByUser User           @relation(fields: [reversedByUserId], references: [id])

  @@map("step_reversals")
}

/// Worker self-check recorded at step completion — one row per checklist item.
/// Visible to the QC manager downstream for review (pass/fail decision).
model ProductionStepCheck {
  id                BigInt   @id @default(autoincrement())
  productionStepId  BigInt   @map("production_step_id")
  checklistItemId   Int      @map("checklist_item_id")
  passed            Boolean
  note              String?
  checkedByUserId   BigInt   @map("checked_by_user_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  productionStep ProductionStep   @relation(fields: [productionStepId], references: [id], onDelete: Cascade)
  checklistItem  QcChecklistItem  @relation(fields: [checklistItemId], references: [id])
  checkedByUser  User             @relation(fields: [checkedByUserId], references: [id])

  @@unique([productionStepId, checklistItemId])
  @@index([productionStepId], map: "idx_production_step_checks_step")
  @@map("production_step_checks")
}

model WorkerMessage {
  id          BigInt   @id @default(autoincrement())
  trailerId   BigInt   @map("trailer_id")
  fromUserId  BigInt   @map("from_user_id")
  toUserId    BigInt   @map("to_user_id")
  messageText String   @map("message_text")
  isRead      Boolean  @default(false) @map("is_read")
  sentAt      DateTime @default(now()) @map("sent_at") @db.Timestamptz

  // Relations
  trailer  Trailer @relation(fields: [trailerId], references: [id])
  fromUser User    @relation("MessageFrom", fields: [fromUserId], references: [id])
  toUser   User    @relation("MessageTo", fields: [toUserId], references: [id])

  @@map("worker_messages")
}

// =============================================================================
// SECTION 3: QUALITY CONTROL
// =============================================================================

model QcChecklistItem {
  id              Int           @id @default(autoincrement())
  departmentId    Int           @map("department_id")
  appliesToSeries QcSeriesScope @default(all) @map("applies_to_series")
  itemLabel       String        @map("item_label") @db.VarChar(300)
  sortOrder       Int           @default(0) @map("sort_order") @db.SmallInt
  isActive        Boolean       @default(true) @map("is_active")
  // NULL → always shown. "*" → shown when trailer has any addon. Otherwise → addon_name match.
  requiresAddonKey String?      @map("requires_addon_key") @db.VarChar(60)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  department          Department            @relation(fields: [departmentId], references: [id])
  checklistResults    QcChecklistResult[]
