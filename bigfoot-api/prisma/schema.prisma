  department   Department   @relation(fields: [departmentId], references: [id])

  @@unique([trailerModelId, departmentId, effectiveFrom])
  @@index([trailerModelId, departmentId], map: "idx_stage_costs_model_dept")
  @@map("trailer_model_stage_costs")
}

