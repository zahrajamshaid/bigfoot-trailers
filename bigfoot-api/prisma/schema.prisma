model DeliveryBatch {
  id                    BigInt              @id @default(autoincrement())
  batchNumber           String              @unique @map("batch_number") @db.VarChar(30)
  driverUserId          BigInt?             @map("driver_user_id")
  destinationLocationId Int?                @map("destination_location_id")
  destinationName       String?             @map("destination_name") @db.VarChar(200)
  batchType             BatchType           @map("batch_type")
  status                DeliveryBatchStatus @default(building)
  departedAt            DateTime?           @map("departed_at") @db.Timestamptz
  completedAt           DateTime?           @map("completed_at") @db.Timestamptz
  createdByUserId       BigInt              @map("created_by_user_id")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  driverUser          User?      @relation("BatchDriver", fields: [driverUserId], references: [id])
  destinationLocation Location?  @relation(fields: [destinationLocationId], references: [id])
  createdByUser       User       @relation("BatchCreatedBy", fields: [createdByUserId], references: [id])
  deliveries          Delivery[]

  @@index([status, createdAt(sort: Desc)], map: "idx_delivery_batches_status_created")
  @@index([driverUserId, status], map: "idx_delivery_batches_driver_status")
  @@index([createdByUserId, createdAt(sort: Desc)], map: "idx_delivery_batches_creator")
  @@map("delivery_batches")
}

model Delivery {
  id                      BigInt         @id @default(autoincrement())
  trailerId               BigInt         @map("trailer_id")
  deliveryBatchId         BigInt?        @map("delivery_batch_id")
  deliveryType            DeliveryType   @map("delivery_type")
  driverUserId            BigInt?        @map("driver_user_id")
  destinationLocationId   Int?           @map("destination_location_id")
  customerDeliveryAddress String?        @map("customer_delivery_address")
  contactPhone            String?        @map("contact_phone") @db.VarChar(20)
  balanceDue              Decimal?       @map("balance_due") @db.Decimal(10, 2)
  paymentCollected        Decimal?       @map("payment_collected") @db.Decimal(10, 2)
  paymentMethod           PaymentMethod? @map("payment_method")
  status                  DeliveryStatus @default(scheduled)
  /// The date a delivery is planned for. Filled in by sales / transport
  /// when the delivery is created so the transport portal can sort by
  /// upcoming date. Null on factory pickups (recorded as already-delivered
  /// in one step) and on legacy rows created before the column existed.
  scheduledDate           DateTime?      @map("scheduled_date") @db.Date
  tcAccepted              Boolean        @default(false) @map("tc_accepted")
  tcAcceptedAt            DateTime?      @map("tc_accepted_at") @db.Timestamptz
  signatureUrl            String?        @map("signature_url")
  gpsLat                  Decimal?       @map("gps_lat") @db.Decimal(10, 7)
  gpsLng                  Decimal?       @map("gps_lng") @db.Decimal(10, 7)
  departedAt              DateTime?      @map("departed_at") @db.Timestamptz
  deliveredAt             DateTime?      @map("delivered_at") @db.Timestamptz
  failReason              String?        @map("fail_reason")
  pickedUpByName          String?        @map("picked_up_by_name") @db.VarChar(200)
  createdByUserId         BigInt         @map("created_by_user_id")
  createdAt               DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  trailer             Trailer           @relation(fields: [trailerId], references: [id])
  deliveryBatch       DeliveryBatch?    @relation(fields: [deliveryBatchId], references: [id])
  driverUser          User?             @relation("DeliveryDriver", fields: [driverUserId], references: [id])
  destinationLocation Location?         @relation(fields: [destinationLocationId], references: [id])
  createdByUser       User              @relation("DeliveryCreatedBy", fields: [createdByUserId], references: [id])
  locationReceipts    LocationReceipt[]
  deliveryPhotos      DeliveryPhoto[]
  smsLogs             SmsLog[]

  @@index([trailerId], map: "idx_deliveries_trailer")
  @@index([driverUserId, status], map: "idx_deliveries_driver")
  @@index([status, deliveryType, createdAt(sort: Desc)], map: "idx_deliveries_status_type")
  @@index([scheduledDate], map: "idx_deliveries_scheduled_date")
  @@map("deliveries")
}

model LocationReceipt {
  id               BigInt   @id @default(autoincrement())
  deliveryId       BigInt   @map("delivery_id")
  trailerId        BigInt   @map("trailer_id")
  receivedByUserId BigInt   @map("received_by_user_id")
  locationId       Int      @map("location_id")
