# =============================================================================
# BIGFOOT TRAILERS API — Production Environment Template
# =============================================================================
# Copy to /opt/bigfoot/.env.production on the droplet (chmod 600). Never
# commit a real .env file. Required variables are enforced by
# src/common/config/env.validation.ts at boot — missing or weak values
# (e.g. the JWT placeholder below) will cause the API to refuse to start.
# =============================================================================

# ---- Core ------------------------------------------------------------------
NODE_ENV=production
PORT=3000
API_PREFIX=v1

# Domain Caddy serves the API on. Auto-issues a Let's Encrypt cert for this.
# An A record must already resolve this to the droplet's public IP.
DOMAIN=api.bigfoottrailers.com

# ---- Database --------------------------------------------------------------
# DigitalOcean Managed PostgreSQL — use the PRIVATE VPC connection string
# from the DO panel (Connection details → "VPC network"). The droplet must
# be listed under the database's "Trusted sources".
#
# NOTE: Do NOT add ?sslmode=... to this URL. node-pg parses sslmode and
# constructs an ssl config that overrides the ca-cert config we pass via
# DATABASE_SSL_CA_PATH below. SSL is enabled and validated strictly because
# DATABASE_SSL_CA_PATH points at the DO CA cert; see prisma.service.ts.
DATABASE_URL=postgresql://doadmin:PASSWORD@private-db-xxx.b.db.ondigitalocean.com:25060/defaultdb

# CA cert for DO Managed PG — download from DO panel (Database → Connection
# details → "Download CA certificate"), save at /opt/bigfoot/do-pg-ca.crt on
# the host, mounted into the api container at this path by docker-compose.prod.yml.
DATABASE_SSL_CA_PATH=/etc/ssl/do-pg-ca.crt

# ---- Redis (internal Docker service) ---------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---- JWT -------------------------------------------------------------------
# Generate with: openssl rand -base64 48
# Must be >= 32 chars; the literal placeholder below is rejected at boot.
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- CORS ------------------------------------------------------------------
# Comma-separated list of origins allowed to call the API in the browser.
# In production this must be your real frontend origin(s) — NOT localhost.
CORS_ORIGINS=https://app.bigfoottrailers.com

# ---- DigitalOcean Spaces (object storage for photos / PDFs) ----------------
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=bigfoot-trailers-prod
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
# CDN endpoint — leave blank (CDN disabled for private files)
DO_SPACES_CDN_URL=

# ---- Twilio (SMS to drivers + customers) ----------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ---- Firebase Cloud Messaging (push notifications) ------------------------
# From a Firebase service-account JSON. The private key must keep its literal
# \n sequences (quoted as shown) — the app un-escapes them at runtime.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@PROJECT.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ---- Rate Limiting (global default; per-route overrides in code) ----------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ---- CI/CD: image tag pulled on the droplet --------------------------------
# Set by the deploy workflow to the commit SHA. Defaults to `latest` for
# manual deploys. To roll back: export IMAGE_TAG=sha-<old-sha> and re-up.
IMAGE_TAG=latest
